{
    "name": "rd-component",
    "version": "0.1.189",
    "type": "module",
    "description": "Reddwarf public component lib",
    "files": [
        "dist"
    ],
    "main": "./dist/rd-component.es.js",
    "module": "./dist/rd-component.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/rd-component.es.js"
        },
        "./dist/style.css": {
            "import": "./dist/style.css",
            "require": "./dist/style.css"
        }
    },
    "scripts": {
        "dev": "vite",
        "clean": "rm -rf dist",
        "build:types": "npx tsc --emitDeclarationOnly",
        "build:lib": "vite build --mode production",
        "build": "npm run clean && npm run build:types && npm run build:lib",
        "watch": "vite build --watch",
        "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "test": "jest",
        "storybook": "storybook dev --host 0.0.0.0 --port 9001 -c .storybook"
    },
    "jest": {
        "transform": {
            "^.+\\.ts?$": "babel-jest",
            "^.+\\.jsx?$": "babel-jest",
            "^.+\\.tsx$": "ts-jest"
        }
    },
    "devDependencies": {
        "@fingerprintjs/fingerprintjs": "^5.2.0",
        "@jest/globals": "^30.4.1",
        "@reduxjs/toolkit": "^2.11.2",
        "@storybook/cli": "^10.4.0",
        "@storybook/react": "^10.4.0",
        "@storybook/react-vite": "^10.4.0",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/event-source-polyfill": "^1.0.5",
        "@types/jest": "^30.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.7.0",
        "@types/react": "^19.2.14",
        "@types/redux-logger": "^3.0.13",
        "axios": "^1.16.1",
        "event-source-polyfill": "^1.0.31",
        "rdjs-wheel": "^0.0.38",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-i18next": "^17.0.7",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.15.0",
        "redux": "^5.0.1",
        "redux-logger": "^3.0.6",
        "typescript": "^6.0.3",
        "uuid": "^14.0.0",
        "vite": "^8.0.12"
    },
    "peerDependencies": {
        "@fingerprintjs/fingerprintjs": "^5.2.0",
        "@reduxjs/toolkit": "^2.2.1",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-redux": "^8.0.5",
        "react-router-dom": "^7.0.2",
        "redux": "^4.2.1",
        "uuid": "^14.0.0"
    },
    "dependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.5",
        "@babel/preset-typescript": "^7.28.5",
        "@types/react": "^19.2.14",
        "@types/redux-logger": "^3.0.13",
        "@types/uuid": "^11.0.0",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-jest": "^30.4.1",
        "jest": "^30.4.2",
        "query-string": "^9.3.1",
        "react-toastify": "^11.1.0",
        "react-turnstile": "^1.1.5",
        "rolldown": "1.0.1",
        "storybook": "^10.4.0",
        "ts-jest": "^29.4.9"
    }
}
